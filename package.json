{
  "name": "web-loom",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall/vite-require-fix.cjs",
    "prepare": "husky install",
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=50",
    "demo:start": "node scripts/dev-helper/demo-runner.js",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "deploy:plugin-docs": "turbo run build --filter=plugin-docs && npm run cf:deploy --workspace=plugin-docs",
    "deploy:plugin-docs:preview": "turbo run build --filter=plugin-docs && npm run cf:upload --workspace=plugin-docs",
    "count-loc": "node scripts/count-loc.js",
    "count-loc:json": "node scripts/count-loc.js --json",
    "count-loc:cloc": "bash scripts/count-loc.sh",
    "count-loc:visualize": "node scripts/visualize-loc.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.5.0",
    "@commitlint/config-conventional": "^17.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.16",
    "prettier": "^3.7.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.2",
    "turbo": "^2.9.18",
    "typescript": "5.8.2",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "tmp": "file:third_party/tmp-safe",
    "@babel/traverse": "7.27.7",
    "@babel/core": "7.27.7",
    "@babel/types": "7.27.7",
    "handlebars": "4.7.9",
    "shell-quote": "1.8.4",
    "ws": "^8.21.0",
    "fast-uri": "^3.1.2",
    "flatted": "^3.4.2",
    "js-cookie": "^3.0.6",
    "rollup": "^4.58.1",
    "express": {
      "path-to-regexp": "0.1.13"
    }
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "sequelize": "^6.37.8"
  }
}
