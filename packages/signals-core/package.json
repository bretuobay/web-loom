{
  "name": "@web-loom/signals-core",
  "description": "Framework-agnostic reactive signals with computed values and effects.",
  "author": "Festus Yeboah<festus.yeboah@hotmail.com>",
  "license": "MIT",
  "private": false,
  "version": "0.7.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.es.js"
    },
    "./rxjs": {
      "types": "./dist/rxjs.d.ts",
      "import": "./dist/rxjs.es.js",
      "require": "./dist/rxjs.cjs.js",
      "default": "./dist/rxjs.es.js"
    }
  },
  "peerDependencies": {
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    }
  },
  "keywords": [
    "signals",
    "reactive",
    "state",
    "computed",
    "effects",
    "typescript",
    "web-loom"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest --watch=false",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "rxjs": "^7.8.2",
    "eslint": "^9.39.1",
    "typescript": "5.8.2",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
