{
  "name": "@web-loom/mvvm-core",
  "description": "A minimal MVVM framework for building reactive web applications.",
  "author": "Festus Yeboah<festus.yeboah@hotmail.com>",
  "license": "MIT",
  "private": false,
  "version": "0.8.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "keywords": [
    "mvvm",
    "signals",
    "zod",
    "web-framework",
    "frontend",
    "react",
    "angular",
    "vue",
    "typescript",
    "dashboard"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest --watch=false",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.x.x",
    "typescript": "~5.7.3",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@web-loom/query-core": "*",
    "@web-loom/signals-core": "*",
    "zod": "^3.25.67"
  }
}
